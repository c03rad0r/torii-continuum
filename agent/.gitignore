# Real config with admin npub + session secret — NEVER commit.
config.yaml

# Node
node_modules/
npm-debug.log*
.env
.env.*

# Runtime state — the wallet, sessions, cost logs, and drafts all live here.
# Treat like cash. Not committed. Not synced. Backed up out-of-band if at all.
memory/wallet/
memory/costs.jsonl
memory/audit.jsonl
memory/sessions/
pending/*.json
!pending/.gitkeep

# Character + memory stack ciphertexts (CONT-CHARACTER-1). Encrypted at
# rest to the operator's own npub, but still per-operator working state
# — not committed. Restore from operator's own backup.
memory/character/
memory/semantic/
memory/intents/
memory/panic/
memory/episodic/
memory/reflect-watermark.json
memory/panic-key-nudge.json
skills/*.enc

# Systemd override if generated locally
*.service.local
