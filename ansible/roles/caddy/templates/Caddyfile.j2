# Continuum — Caddy reverse proxy configuration
# Auto-generated by ansible. Do not edit manually.

{{ continuum_agent_domain }} {
    tls {{ acme_email }}

    # Reverse proxy to Continuum agent daemon
    reverse_proxy 127.0.0.1:{{ continuum_port }}

    # Security headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Request size limit (Cashu tokens can be large)
    request_body {
        max_size 512KB
    }
}

{{ continuum_domain }} {
    tls {{ acme_email }}

    # Serve the Continuum frontend (static Vite build)
    root * {{ continuum_frontend_dir }}/dist
    file_server

    # SPA fallback — serve index.html for all routes
    try_files {path} /index.html

    # Security headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}
