# Continuum Ansible Deployment — Environment Variables
# Copy this file to .env and fill in your values.
# Then: source .env && ansible-playbook ansible/playbooks/deploy.yml

# ──────────────────────────────────────────────
# REQUIRED
# ──────────────────────────────────────────────

# Your VPS IP address
CONTINUUM_VPS_IP=1.2.3.4

# SSH user (root or a sudo-enabled user)
CONTINUUM_VPS_USER=root

# SSH key path (default: ~/.ssh/id_ed25519)
# CONTINUUM_SSH_KEY=~/.ssh/id_ed25519

# Your npub from Plebeian Signer (or any NIP-07 browser extension)
# Get it from: Plebeian Signer → Settings → Copy Public Key
CONTINUUM_ADMIN_NPUB=npub1yourkeyhere

# ──────────────────────────────────────────────
# DOMAIN (required unless using localhost)
# ──────────────────────────────────────────────

# Base domain for the Continuum instance
BASE_DOMAIN=example.com

# Frontend URL (defaults to continuum.<base_domain>)
# CONTINUUM_DOMAIN=continuum.example.com

# Agent API URL (defaults to agent.<base_domain>)
# CONTINUUM_AGENT_DOMAIN=agent.example.com

# ──────────────────────────────────────────────
# TLS / Let's Encrypt
# ──────────────────────────────────────────────

# Email for Let's Encrypt notifications
ACME_EMAIL=admin@example.com

# ──────────────────────────────────────────────
# OPTIONAL — Cloudflare DNS automation
# ──────────────────────────────────────────────

# If set, the playbook will automatically create DNS A records
# Leave blank to manage DNS manually
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ──────────────────────────────────────────────
# OPTIONAL — Cashu wallet configuration
# ──────────────────────────────────────────────

# Mints to accept (comma-separated URLs)
# CONTINUUM_CASHU_MINTS=https://mint.minibits.cash/Bitcoin,https://mint.coinos.io

# Balance thresholds (sats)
# CONTINUUM_LOW_BALANCE_WARN_SATS=500
# CONTINUUM_HARD_FLOOR_SATS=100

# ──────────────────────────────────────────────
# OPTIONAL — Routstr model configuration
# ──────────────────────────────────────────────

# CONTINUUM_ROUTSTR_ENDPOINT=https://api.routstr.com
# CONTINUUM_ROUTSTR_MODEL_CHAT=deepseek-chat-v3
# CONTINUUM_ROUTSTR_MODEL_CODING=deepseek-coder-v2
