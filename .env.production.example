# Continuum production build-time env.
#
# Copy to .env.production and edit before `npm run build` when installing on
# a VPS. On pplx.app (agent-less demo), leave everything blank — agent.js
# short-circuits every /api call into offline mode.
#
# For a VPS install at https://example.com/continuum:
#   VITE_AGENT_URL=/continuum
#
# For a VPS install at https://example.com (root_app=continuum, no subpath):
#   VITE_AGENT_URL=
#
# For a cross-origin API on a different host (rare):
#   VITE_AGENT_URL=https://api.example.com
#
# The Ansible installer sets this automatically based on inventory vars.

VITE_AGENT_URL=/continuum
