---
# Ansible inventory for a single-VPS Torii deployment.
#
# Copy to inventory.yml and edit. `ansible_host` is the VPS IP or hostname.
# `ansible_user` should be a sudoer; use ansible_become_pass if it needs a
# password, or set up passwordless sudo (recommended).

all:
  children:
    torii:
      hosts:
        torii-vps:
          ansible_host: 203.0.113.10           # <-- replace with your VPS IP
          ansible_user: root                    # or a sudoer with passwordless sudo
          ansible_python_interpreter: /usr/bin/python3
          # ansible_ssh_private_key_file: ~/.ssh/id_ed25519_torii
