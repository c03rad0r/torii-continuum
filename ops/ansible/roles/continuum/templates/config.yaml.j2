# Torii Continuum — Agent Configuration
# Rendered by Ansible. Do NOT edit by hand — re-run the playbook instead.
# See agent/config.example.yaml for the annotated version.

admin_npub: "{{ admin_npub }}"
session_secret: "{{ session_secret }}"
session_ttl_sec: 86400

server:
  host: "{{ continuum_agent_host }}"
  port: {{ continuum_agent_port }}
  cors_origins:
    - "https://{{ torii_domain }}"
    - "http://localhost:5180"
    - "http://127.0.0.1:5180"

cashu:
  mints:
{% for mint in cashu_mints | default(['https://mint.minibits.cash/Bitcoin', 'https://mint.coinos.io']) %}
    - "{{ mint }}"
{% endfor %}
  low_balance_warn_sats: 500
  hard_floor_sats: 100

routstr:
  endpoint: "https://api.routstr.com"
  models:
    chat:      "deepseek-chat-v3"
    coding:    "deepseek-coder-v2"
    summarise: "llama-3.1-8b-instruct"
    routing:   "llama-3.1-8b-instruct"
    embed:     "auto"
  fallback:
    enabled: false
  limits:
    max_tokens_out: 2048
    max_sats_per_request: 50

ollama:
  enabled: {{ torii_enable_ollama | default(false) | bool | lower }}
  endpoint: "http://{{ ollama_bind | default('127.0.0.1:11434') }}"
  model: "{{ ollama_chat_model | default('llama3.2:3b') }}"
  models:
    chat:    "{{ ollama_chat_model | default('llama3.2:3b') }}"
    reflect: "{{ ollama_reflect_model | default('llama3.2:3b') }}"
  temperature: {{ ollama_temperature | default(0.4) }}
  timeout_ms: {{ ollama_timeout_ms | default(60000) }}

model_router:
  strategy: "{{ ollama_router_strategy | default('routstr_first') }}"

skills:
  chat:
    enabled: true
    read_paths:
      - "memory/notes/"
      - "memory/sessions/"
  brain_read:
    enabled: false
  brain_write:
    enabled: false
  todo_patch:
    enabled: false
  nostr_draft:
    enabled: false

character:
  character_md: "CHARACTER.md"
  sources_md: "SOURCES.md"
  require_unlock: false
  refuse_on_root_mismatch: false

reflect:
  schedule: ""
  limit_per_pass: 10

destructive:
  cooldown_sec: 60
  required_signatures: 2

panic_key:
  enabled: false
  nudge_on_first_unlock: true

logging:
  destination: "stdout"
  level: "info"
  cost_log: "memory/costs.jsonl"
  audit_log: "memory/audit.jsonl"
